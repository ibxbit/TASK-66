{
  "name": "museum-ops-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:component": "vitest run tests/component --reporter=basic",
    "test:integration": "vitest run tests/integration --reporter=basic",
    "test:frontend": "npm run test:unit && npm run test:component && npm run test:integration",
    "test:e2e:setup": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:real": "playwright test --config=playwright.real.config.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@playwright/test": "^1.52.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^26.1.0",
    "vite": "^5.4.2",
    "vitest": "^2.1.1"
  }
}

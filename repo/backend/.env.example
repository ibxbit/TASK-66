NODE_ENV=development
PORT=8080
MONGO_URI=mongodb://museum_user:museum_pass@localhost:27017/museum_ops?authSource=admin
# Include :8888 because Swagger UI runs on the exposed API host and sends Origin: http://localhost:8888
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:8888
ENABLE_SWAGGER=false

SESSION_SECRET=local-dev-session-secret-change-me
SESSION_COOKIE_NAME=museum_sid
SESSION_COOKIE_SAME_SITE=strict
SESSION_COOKIE_SECURE=false
SESSION_IDLE_TTL_SECONDS=1800
SESSION_ABSOLUTE_TTL_SECONDS=43200

MIN_PASSWORD_LENGTH=12
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
FAILED_LOGIN_WINDOW_MINUTES=15
STEP_UP_TTL_MINUTES=10

SEARCH_CACHE_TTL_SECONDS=600
WAITLIST_PROMOTION_EXPIRY_MINUTES=60
INBOX_RETENTION_DAYS=90

REPORT_SCHEDULE_TIMEZONE=America/New_York
REPORT_SCHEDULE_TIME=02:00
RECONCILIATION_DIR=./reconciliation

ENABLE_DEV_SEED=false

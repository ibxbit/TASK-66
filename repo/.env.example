# Docker Compose environment — copy to .env and fill in values
SESSION_SECRET=change-me-to-a-strong-random-value-at-least-32-chars
SESSION_COOKIE_SECURE=false
# Set SESSION_COOKIE_SECURE=true when behind TLS in production

MONGO_INITDB_ROOT_USERNAME=museum_user
MONGO_INITDB_ROOT_PASSWORD=museum_pass
MONGO_INITDB_DATABASE=museum_ops
